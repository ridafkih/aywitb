{
  "name": "aywitb",
  "module": "dist/index.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./plugin": "./dist/plugin.js"
  },
  "scripts": {
    "build": "bun run build:js && bun run build:plugin && bun run build:types",
    "build:js": "bun build ./src/index.ts --outdir ./dist --target bun --format esm --sourcemap=external",
    "build:plugin": "bun build ./src/plugin.ts --outdir ./dist --target bun --format esm --entry-naming plugin.js",
    "build:types": "tsc --noEmit false --declaration --emitDeclarationOnly --outDir ./dist",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
